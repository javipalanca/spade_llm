# SPADE LLM Examples — Environment Configuration
#
# Copy to the project root:  cp .env.example .env
#
# This example uses LM Studio as the provider.
# Any OpenAI-compatible endpoint works the same way, just change the values.
#
# LiteLLM reads OPENAI_API_KEY and OPENAI_API_BASE automatically, so you only
# need to set them here, no credentials are hardcoded in the example scripts.


# XMPP Server
XMPP_SERVER=localhost


# LLM Provider
# LM Studio example (local, free):
OPENAI_API_KEY=lm-studio
OPENAI_API_BASE=http://localhost:1234/v1
LLM_MODEL=openai/<model-name>

# OpenAI example:
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=
# LLM_MODEL=openai/<model-name>

# Anthropic example:
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=anthropic/<model-name>


# Embedding Model (RAG examples)
EMBEDDING_MODEL=openai/<embedding-model>


# MCP Tool Servers (MCP / GitHub examples)
#
# GitHub / Notion / Gmail (github_issues_monitor_complex.py)
# Obtain these URLs from composio.dev after connecting your accounts.
#
# GITHUB_MCP_URL=https://mcp.composio.dev/composio/server/YOUR_SERVER_ID/mcp
# NOTION_MCP_URL=https://mcp.composio.dev/composio/server/YOUR_SERVER_ID/mcp
# GMAIL_MCP_URL=https://mcp.composio.dev/composio/server/YOUR_SERVER_ID/mcp
GITHUB_MCP_URL=
NOTION_MCP_URL=
GMAIL_MCP_URL=

# MCP: Valencia Smart City (valencia_smartCity_mcp.py, trip_planner.py)
#
# Leave unset to fetch and run directly from GitHub (requires uv).
# Set to a local path if you have cloned https://github.com/olafmeneses/SmartCityMCP
#
# VALENCIA_MCP_PATH=/path/to/SmartCityMCP/valencia_smart_city_mcp.py
VALENCIA_MCP_PATH=


# Memory
# SPADE_LLM_MEMORY_PATH=~/.spade_llm/memory
